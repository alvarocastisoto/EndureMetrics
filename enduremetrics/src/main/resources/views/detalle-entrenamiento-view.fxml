<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #f4f6f7;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.alvaro.enduremetrics.controller.DetalleEntrenamientoController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0"
              style="-fx-background-color: white; -fx-padding: 15 25; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
            <Button mnemonicParsing="false" onAction="#volverAlCalendario"
                    style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;"
                    text="← Volver al Calendario"/>
            <Separator orientation="VERTICAL"/>
            <Label text="Análisis de la Actividad" textFill="#2c3e50">
                <font>
                    <Font name="System Bold" size="20.0"/>
                </font>
            </Label>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="25.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
            </padding>

            <HBox alignment="CENTER" spacing="40.0"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5); -fx-padding: 30;">

                <VBox alignment="CENTER" spacing="5.0">
                    <Label fx:id="lblDeporte" text="---" textFill="#2c3e50">
                        <font>
                            <Font name="System Bold" size="28.0"/>
                        </font>
                    </Label>
                    <Label fx:id="lblFecha" text="---" textFill="#7f8c8d">
                        <font>
                            <Font size="14.0"/>
                        </font>
                    </Label>
                </VBox>

                <Separator orientation="VERTICAL"/>

                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="Distancia" textFill="#7f8c8d">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                    <Label fx:id="lblDistancia" text="---" textFill="#3498db">
                        <font>
                            <Font name="System Bold" size="32.0"/>
                        </font>
                    </Label>
                </VBox>

                <Separator orientation="VERTICAL"/>

                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="Tiempo en Movimiento" textFill="#7f8c8d">
                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>
                    <Label fx:id="lblDuracion" text="---" textFill="#2ecc71">
                        <font>
                            <Font name="System Bold" size="32.0"/>
                        </font>
                    </Label>
                </VBox>
            </HBox>

            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">

                <Tab text="Resumen Fisiológico">
                    <VBox spacing="15.0"
                          style="-fx-background-color: white; -fx-background-radius: 0 0 8 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5); -fx-padding: 25;">
                        <GridPane hgap="30.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120.0"/>
                                <ColumnConstraints minWidth="80.0"/>
                                <ColumnConstraints minWidth="120.0"/>
                                <ColumnConstraints minWidth="80.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0"/>
                            </rowConstraints>

                            <Label style="-fx-font-weight: bold;" text="Rendimiento (W/Kg):" textFill="#7f8c8d" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="lblPotencia" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <Label style="-fx-font-weight: bold;" text="Frec. Cardíaca:" textFill="#7f8c8d" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="lblFrecCardiaca" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <Label style="-fx-font-weight: bold;" text="Estrés (TSS):" textFill="#7f8c8d" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                            <Label fx:id="lblTss" text="---" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                            <Label style="-fx-font-weight: bold;" text="Desnivel:" textFill="#7f8c8d" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                            <Label fx:id="lblDesnivel" text="---" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        </GridPane>
                    </VBox>
                </Tab>

                <Tab text="Análisis por Vueltas">
                    <VBox spacing="10.0"
                          style="-fx-background-color: white; -fx-background-radius: 0 0 8 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5); -fx-padding: 20;">

                        <HBox alignment="CENTER_RIGHT">
                            <Button text="📋 Copiar" onAction="#copiarTabla"
                                    style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15; -fx-background-radius: 4;"/>
                        </HBox>

                        <TableView fx:id="tablaVueltas" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                            <columns>
                                <TableColumn fx:id="colVuelta" text="#" prefWidth="30" style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="90"/>

                                <TableColumn text="Volumen">
                                    <columns>
                                        <TableColumn fx:id="colDistancia" text="Dist. (m)" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colTiempo" text="Tiempo" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colTiempoMov" text="T. Mov" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                    </columns>
                                </TableColumn>

                                <TableColumn text="Ritmos (min/km)">
                                    <columns>
                                        <TableColumn fx:id="colRitmo" text="Medio" prefWidth="60" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colRitmoOptimo" text="Óptimo" prefWidth="60" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colGap" text="GAP" prefWidth="60" style="-fx-alignment: CENTER-RIGHT;"/>
                                    </columns>
                                </TableColumn>

                                <TableColumn text="Motor Aeróbico">
                                    <columns>
                                        <TableColumn fx:id="colFCMin" text="FC Min" prefWidth="60" style="-fx-alignment: CENTER-RIGHT; -fx-text-fill: #e74c3c;"/>
                                        <TableColumn fx:id="colFC" text="FC Med" prefWidth="60" style="-fx-alignment: CENTER-RIGHT; -fx-text-fill: #e74c3c;"/>
                                        <TableColumn fx:id="colFCMax" text="FC Máx" prefWidth="60" style="-fx-alignment: CENTER-RIGHT; -fx-text-fill: #e74c3c;"/>
                                        <TableColumn fx:id="colCalorias" text="Kcal" prefWidth="60" style="-fx-alignment: CENTER-RIGHT;"/>
                                    </columns>
                                </TableColumn>


                                <TableColumn text="Dinámica de Carrera">
                                    <columns>
                                        <TableColumn fx:id="colCadencia" text="Cad. Med" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colCadenciaMax" text="Cad. Máx" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colZancada" text="Zancada (m)" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colTCS" text="TCS (ms)" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colEquilibrio" text="Izq/Der %" prefWidth="80" style="-fx-alignment: CENTER;"/>
                                        <TableColumn fx:id="colOscilacion" text="Osc. Vert (cm)" prefWidth="90" style="-fx-alignment: CENTER-RIGHT;"/>
                                        <TableColumn fx:id="colRatio" text="Ratio Vert %" prefWidth="90" style="-fx-alignment: CENTER-RIGHT;"/>
                                    </columns>
                                </TableColumn>

                                <TableColumn text="Terreno">
                                    <columns>
                                        <TableColumn fx:id="colAscenso" text="+ (m)" prefWidth="50" style="-fx-alignment: CENTER-RIGHT; -fx-text-fill: #27ae60;"/>
                                        <TableColumn fx:id="colTemp" text="Temp (ºC)" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;"/>
                                    </columns>
                                </TableColumn>

                            </columns>
                        </TableView>

                    </VBox>
                </Tab>

            </TabPane>
        </VBox>
    </center>
</BorderPane>