<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.ColumnConstraints?>
<VBox prefHeight="700.0" prefWidth="900.0" spacing="15.0" style="-fx-background-color: #ffffff;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.alvaro.enduremetrics.controller.CalendarioController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label fx:id="labelMesAnio" text="Marzo 2026" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="26.0"/>
            </font>
        </Label>
        <HBox spacing="10.0">
            <Button onAction="#mesAnterior" style="-fx-background-color: #ecf0f1;" text="&lt;"/>
            <Button onAction="#mesSiguiente" style="-fx-background-color: #ecf0f1;" text="&gt;"/>
        </HBox>
    </HBox>

    <GridPane fx:id="gridCalendario" hgap="5.0" vgap="5.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-border-color: #dee2e6;">
        <columnConstraints>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
        </columnConstraints>
        <Label text="LUN" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        <Label text="MAR" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        <Label text="MIE" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        <Label text="JUE" GridPane.columnIndex="3" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        <Label text="VIE" GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        <Label text="SAB" GridPane.columnIndex="5" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        <Label text="DOM" GridPane.columnIndex="6" GridPane.rowIndex="0" GridPane.halignment="CENTER"
               style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
    </GridPane>
</VBox>